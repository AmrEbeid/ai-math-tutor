# Zeluu server environment — EXAMPLE / placeholders only. Do NOT put real secrets here.
# Copy to `.env` (which is gitignored) and fill in real values locally / in Vercel.
# Classification + validation: docs/specs/SPEC-STAGE1-C-env-secret-validation-plan.md

# Supabase — URL + anon key are public-safe (anon key safe ONLY because RLS is enforced).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key BYPASSES RLS — server only; never expose to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# AI provider secret (server only).
OPENAI_API_KEY=

# Payment (Lemon Squeezy) — API secret + webhook signature secret (server only).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Child session token HMAC signing secret (server only; never log or return in errors).
CHILD_JWT_SECRET=

# CORS allowed origin, e.g. https://zeluu.com
ALLOWED_ORIGIN=
